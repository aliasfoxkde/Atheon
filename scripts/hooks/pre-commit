#!/bin/bash
# Pre-commit hook for Atheon-Enhanced
# Only runs checks relevant to what was actually staged.
# Install: git config core.hooksPath scripts/hooks

set -euo pipefail

export PATH="$PATH:/usr/local/go/bin:/c/Program Files/Go/bin:$HOME/go/bin:$HOME/.local/go/bin"

echo "=== Pre-commit quality gate ==="

# Classify staged files
STAGED_GO=$(git diff --cached --name-only | grep '\.go$' || true)
STAGED_PATTERNS=$(git diff --cached --name-only | grep '^community/.*\.yaml$' || true)

# Nothing code-related staged — fast exit
if [ -z "$STAGED_GO" ] && [ -z "$STAGED_PATTERNS" ]; then
    echo "No Go or pattern changes staged — skipping."
    exit 0
fi

# Require Go for any of the below
if ! command -v go &>/dev/null; then
    echo "ERROR: 'go' not found. Install Go: https://go.dev/dl/"
    exit 1
fi

if [ -n "$STAGED_GO" ]; then
    # --- Format (auto-fix and re-stage) ---
    gofmt -w . 2>/dev/null || true
    if [ -n "$(git diff --name-only -- '*.go')" ]; then
        git add -u -- '*.go'
        echo "  ✓ gofmt auto-fixed"
    else
        echo "  ✓ gofmt clean"
    fi

    # goimports if available
    if command -v goimports &>/dev/null || [ -x "./tools/goimports" ]; then
        GOIMPORTS=$(command -v goimports 2>/dev/null || echo "./tools/goimports")
        "$GOIMPORTS" -w . 2>/dev/null || true
        if [ -n "$(git diff --name-only -- '*.go')" ]; then
            git add -u -- '*.go'
            echo "  ✓ imports auto-fixed"
        fi
    fi

    # --- Vet ---
    echo "  Running go vet..."
    if ! go vet ./... 2>&1; then
        echo "ERROR: go vet failed"
        exit 1
    fi
    echo "  ✓ go vet passed"

    # --- Selective tests ---
    # Determine which packages to test.
    # Rule: if core/ is touched, its change can affect every consumer → test all.
    # Otherwise test only the packages that actually changed.
    CHANGED_DIRS=$(echo "$STAGED_GO" | xargs -I{} dirname {} | sort -u)

    if echo "$CHANGED_DIRS" | grep -qE '^core$'; then
        TEST_PKGS="./..."
        echo "  core/ changed — running full test suite..."
    else
        TEST_PKGS=$(echo "$CHANGED_DIRS" | sed 's|^|./|' | tr '\n' ' ')
        echo "  Running tests for changed packages: $TEST_PKGS"
    fi

    TMPDIR_HOOK=$(mktemp -d)
    trap "rm -rf $TMPDIR_HOOK" EXIT
    COV_OUT="$TMPDIR_HOOK/coverage.out"

    if ! go test $TEST_PKGS -p 1 -coverprofile="$COV_OUT" -timeout 5m > "$TMPDIR_HOOK/test.log" 2>&1; then
        echo "ERROR: Tests failed:"
        cat "$TMPDIR_HOOK/test.log"
        exit 1
    fi
    echo "  ✓ Tests passed"

    # Coverage check only when running full suite (partial runs skew the number)
    if echo "$TEST_PKGS" | grep -q "\./\.\.\."; then
        MIN_COV=70
        COV=$(go tool cover -func="$COV_OUT" | grep total: | awk '{print $3}' | tr -d '%' | cut -d. -f1)
        echo "  Coverage: ${COV}%"
        if [ "${COV:-0}" -lt "$MIN_COV" ]; then
            echo "ERROR: Coverage ${COV}% below minimum ${MIN_COV}%"
            exit 1
        fi
        echo "  ✓ Coverage ${COV}% meets threshold"
    fi
fi

# --- Bundle rebuild on pattern changes ---
if [ -n "$STAGED_PATTERNS" ]; then
    echo "  Pattern files changed — rebuilding bundle..."
    BUNDLE_LOG=$(mktemp)
    if go run ./bundler > /dev/null 2> "$BUNDLE_LOG"; then
        git add core/patterns.bundle
        echo "  ✓ Bundle rebuilt"
        # Even on success, surface any per-file skip warnings so the
        # contributor sees when a pattern was dropped (regex corruption,
        # duplicate name, missing field). Otherwise a broken YAML slips
        # in silently and the bundled pattern count drifts.
        if [ -s "$BUNDLE_LOG" ]; then
            echo "  ! Bundler warnings (file skipped):"
            sed 's/^/      /' "$BUNDLE_LOG"
        fi
        rm -f "$BUNDLE_LOG"
    else
        echo "ERROR: Bundle rebuild failed"
        cat "$BUNDLE_LOG"
        rm -f "$BUNDLE_LOG"
        exit 1
    fi
fi

echo "=== All checks passed ==="
exit 0
