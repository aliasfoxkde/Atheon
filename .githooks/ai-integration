#!/bin/bash
# AI Integration Hook - Catch Bad Patterns Early for AI Feedback
# This hook integrates Atheon scanning into your development workflow for AI-assisted development

set -e

echo "=== 🤖 AI-ASSISTED DEVELOPMENT VALIDATION ==="

# Check if Atheon binary exists
if [ ! -f ./atheon ] && [ ! -f ../../atheon ]; then
    echo "Atheon binary not found, building..."
    go build -o atheon . || echo "⚠️  Could not build Atheon, skipping AI validation"
    exit 0
fi

# Determine which Atheon binary to use
if [ -f ./atheon ]; then
    ATHEON="./atheon"
else
    ATHEON="../../atheon"
fi

echo "Using Atheon: $ATHEON"

# AI Development Pattern Categories to Check
AI_PATTERNS="ai-detection,code-quality,devops"

echo "=== 🔍 Scanning for AI-Generated Code Patterns ==="

# Scan staged or modified files
if git diff --cached --name-only | grep -E '\.go$|\.py$|\.js$|\.ts$' > /dev/null; then
    echo "Scanning staged code files for AI-generated patterns..."

    # Create temporary file with staged content
    TEMP_DIR=$(mktemp -d)
    trap "rm -rf $TEMP_DIR" EXIT

    # Extract staged files
    git diff --cached --name-only | grep -E '\.go$|\.py$|\.js$|\.ts$' | while read file; do
        if [ -f "$file" ]; then
            mkdir -p "$TEMP_DIR/$(dirname "$file")"
            git show ":$file" > "$TEMP_DIR/$file"
        fi
    done

    # Scan with Atheon for AI-generated patterns
    if $ATHEON "$TEMP_DIR" --categories=$AI_PATTERNS --json > /tmp/ai-findings.json 2>&1; then
        FINDINGS_COUNT=$(jq 'length' /tmp/ai-findings.json 2>/dev/null || echo "0")

        if [ "$FINDINGS_COUNT" -gt 0 ]; then
            echo "=== ⚠️  AI-Generated Code Patterns Detected ==="
            echo "Found $FINDINGS_COUNT potential AI-generated patterns:"
            echo ""

            # Group findings by type
            AI_TEMPLATES=$(jq '[.[] | select(.pattern | test("template|in conclusion|notably|significantly"; "i"))] | length' /tmp/ai-findings.json 2>/dev/null || echo "0")
            AI_BUZZWORDS=$(jq '[.[] | select(.pattern | test("comprehensive|robust|seamless|leverage"; "i"))] | length' /tmp/ai-findings.json 2>/dev/null || echo "0")
            AI_EMOJIS=$(jq '[.[] | select(.pattern | test("emoji|🤖|✨|🚀|💡"; "i"))] | length' /tmp/ai-findings.json 2>/dev/null || echo "0")
            AI_INCOMPLETE=$(jq '[.[] | select(.pattern | test("implement this|add your|fix this|placeholder"; "i"))] | length' /tmp/ai-findings.json 2>/dev/null || echo "0")

            echo "📊 Pattern Breakdown:"
            echo "  • AI Templates/Phrases: $AI_TEMPLATES"
            echo "  • AI Buzzwords: $AI_BUZZWORDS"
            echo "  • AI Emojis: $AI_EMOJIS"
            echo "  • Incomplete Code: $AI_INCOMPLETE"
            echo ""

            # Show some examples
            echo "🔍 Sample Findings:"
            jq -r '.[] | select(.pattern | test("template|in conclusion"; "i")) | "\(.pattern) - \(.file):\(.line)"' /tmp/ai-findings.json 2>/dev/null | head -5 || echo "No template findings"
            echo ""

            # AI Feedback Message
            echo "=== 🤖 AI Development Feedback ==="
            echo "• Review AI-generated code patterns before committing"
            echo "• Replace generic AI responses with specific implementation"
            echo "• Remove AI-generated placeholder text"
            echo "• Consider if AI detection patterns should be disabled for this code"
            echo ""
            echo "💡 Quick Actions:"
            echo "  • Review findings: jq '.' /tmp/ai-findings.json"
            echo "  • Disable specific patterns: ./atheon disable pattern-name"
            echo "  • Scan without AI patterns: ./atheon . --categories=secrets"
            echo ""

            # Ask for confirmation
            read -p "Continue with commit despite AI patterns? (y/N): " choice
            case "$choice" in
                [Yy]* )
                    echo "Proceeding with commit..."
                    ;;
                * )
                    echo "Commit cancelled by user"
                    echo "💡 Fix AI-generated patterns and commit again"
                    exit 1
                    ;;
            esac
        else
            echo "✅ No AI-generated patterns detected"
        fi
    else
        echo "⚠️  Scan had issues, continuing..."
    fi
else
    echo "ℹ️  No code files staged for commit"
fi

# Check for quality enforcement patterns
echo "=== 🔍 Checking Development Quality Patterns ==="

QUALITY_PATTERNS="skip-tests,git-force-push,hardcoded-url,insecure-flag"
if git diff --cached --name-only | grep -E '\.go$|\.py$|\.js$|\.ts$' > /dev/null; then
    echo "Scanning for quality enforcement patterns..."

    TEMP_DIR=$(mktemp -d)
    trap "rm -rf $TEMP_DIR" EXIT

    git diff --cached --name-only | grep -E '\.go$|\.py$|\.js$|\.ts$' | while read file; do
        if [ -f "$file" ]; then
            mkdir -p "$TEMP_DIR/$(dirname "$file")"
            git show ":$file" > "$TEMP_DIR/$file"
        fi
    done

    if $ATHEON "$TEMP_DIR" --categories=code-quality --json > /tmp/quality-findings.json 2>&1; then
        QUALITY_ISSUES=$(jq '[.[] | select(.pattern | test("skip-tests|force-push|hardcoded|insecure"; "i"))] | length' /tmp/quality-findings.json 2>/dev/null || echo "0")

        if [ "$QUALITY_ISSUES" -gt 0 ]; then
            echo "=== ⚠️  Quality Issues Detected ==="
            echo "Found $QUALITY_ISSUES potential quality issues:"
            echo ""

            # Show quality findings
            jq -r '.[] | select(.pattern | test("skip-tests|force-push|hardcoded|insecure"; "i")) | "\(.pattern) - \(.file):\(.line)"' /tmp/quality-findings.json 2>/dev/null | head -3
            echo ""
            echo "💡 Consider addressing these quality issues before committing"
        else
            echo "✅ No critical quality issues detected"
        fi
    fi
fi

echo ""
echo "=== ✅ AI-INTEGRATED DEVELOPMENT CHECK COMPLETE ==="
echo "Next steps:"
echo "  • Review AI-generated code patterns"
echo "  • Address quality enforcement findings"
echo "  • Commit with confidence: git commit"
echo "  • Get real-time feedback on your code"

# Cleanup
rm -f /tmp/ai-findings.json /tmp/quality-findings.json