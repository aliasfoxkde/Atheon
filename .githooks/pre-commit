#!/bin/bash
# Pre-commit hook for Atheon-Enhanced
# Validates Go code quality before each commit.
# Install: git config core.hooksPath .githooks

set -euo pipefail

echo "=== Pre-commit: Atheon quality gate ==="

# Only run Go checks when Go files are staged
if ! git diff --cached --name-only | grep -qE '\.go$'; then
    echo "No Go changes staged — skipping code checks."
    exit 0
fi

echo "Go changes detected — running quality gate..."

# Require Go
if ! command -v go &>/dev/null; then
    echo "ERROR: 'go' not found. Install Go: https://go.dev/dl/"
    exit 1
fi

# --- Formatting (auto-fix, then re-stage) ---
echo "  Formatting staged Go files..."
# Auto-format all Go files; gofmt is idempotent so this is safe.
gofmt -w . 2>/dev/null || true
# Re-stage any files gofmt changed so the commit includes the fix.
if [ -n "$(git diff --name-only -- '*.go')" ]; then
    git add -u -- '*.go'
    echo "  ✓ gofmt auto-fixed and re-staged"
else
    echo "  ✓ gofmt clean"
fi

# --- Imports (auto-fix, then re-stage) ---
if command -v goimports &>/dev/null; then
    goimports -w . 2>/dev/null || true
    if [ -n "$(git diff --name-only -- '*.go')" ]; then
        git add -u -- '*.go'
        echo "  ✓ Imports auto-fixed"
    fi
fi

# --- Vet ---
echo "  Running go vet..."
if ! go vet ./... 2>&1; then
    echo "ERROR: go vet failed"
    exit 1
fi
echo "  ✓ go vet passed"

# --- Tests ---
echo "  Running tests with coverage..."
TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT
COVERAGE_OUT="$TMPDIR/coverage.out"

if ! go test ./... -p 1 -coverprofile="$COVERAGE_OUT" -timeout 15m > "$TMPDIR/test.log" 2>&1; then
    echo "ERROR: Tests failed:"
    cat "$TMPDIR/test.log"
    exit 1
fi
echo "  ✓ All tests passed"

# --- Coverage threshold ---
MIN_COVERAGE=70
if command -v go &>/dev/null && [ -f "$COVERAGE_OUT" ]; then
    COV=$(go tool cover -func="$COVERAGE_OUT" | grep total: | awk '{print $3}' | tr -d '%' | cut -d. -f1)
    echo "  Coverage: ${COV}%"
    if [ "${COV:-0}" -lt "$MIN_COVERAGE" ]; then
        echo "ERROR: Coverage ${COV}% is below minimum ${MIN_COVERAGE}%"
        exit 1
    fi
    echo "  ✓ Coverage ${COV}% meets threshold"
fi

# --- Staticcheck (optional) ---
if command -v staticcheck &>/dev/null; then
    echo "  Running staticcheck..."
    if ! staticcheck ./... 2>&1; then
        echo "WARNING: staticcheck found issues (non-blocking)"
    fi
fi

# --- Pattern bundle update ---
if git diff --cached --name-only | grep -qE '^community/.*\.yaml$'; then
    echo "  Pattern files changed — rebuilding bundle..."
    if command -v go &>/dev/null; then
        go run ./bundler > /dev/null 2>&1 && git add core/patterns.bundle && echo "  ✓ Bundle updated"
    fi
fi

echo "=== Pre-commit: all checks passed ==="
exit 0
