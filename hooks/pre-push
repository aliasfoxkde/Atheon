#!/bin/bash
# Pre-push hook for Atheon-Enhanced
# Runs a final build + test verification before push.
# Install: git config core.hooksPath hooks

set -euo pipefail

echo "=== Pre-push: final verification ==="

if ! command -v go &>/dev/null; then
    echo "WARNING: 'go' not found — skipping pre-push checks"
    exit 0
fi

# Build check
echo "  Building..."
if ! go build ./... 2>&1; then
    echo "ERROR: Build failed"
    exit 1
fi
echo "  ✓ Build passed"

# Run tests (no race flag needed here — pre-commit already ran it)
echo "  Running tests..."
if ! go test ./... -timeout 10m 2>&1; then
    echo "ERROR: Tests failed"
    exit 1
fi
echo "  ✓ Tests passed"

echo "=== Pre-push: all checks passed ==="
exit 0
