# Paths excluded from secret scanning.
# Supports exact paths, directory prefixes, and * globs.

# Test fixtures and test files use placeholder values that look like real secrets.
test/
*_test.go

# Compiled release binaries — binary content triggers false positives.
atheon-linux
atheon-linux-amd64
atheon-macos
atheon-macos-amd64
atheon-macos-arm64
